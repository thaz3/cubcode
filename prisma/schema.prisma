generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AgeBand {
  LITTLE_CUBS
  CORE_CUBS
  TRAIL_CUBS
  LEGACY_BUILDERS
}

enum SupervisionLevel {
  DIRECT
  NEARBY
  INDEPENDENT
}

enum ProofStyle {
  PARENT_APPROVAL
  SHORT_REFLECTION
  CHECKLIST
}

enum TaskStatus {
  AVAILABLE
  CLAIMED
  IN_PROGRESS
  SUBMITTED
  SENT_BACK
  REJECTED
  APPROVED
  COMPLETED
}

enum TaskProofType {
  PARENT_APPROVAL
  SHORT_REFLECTION
  CHECKLIST
  TIME_LOG
  PERFORMANCE_VIDEO
  SLIDESHOW
}

enum TaskCategory {
  FOCUS_BLOCK
  SCHOOL
  CHORE
  ATTITUDE
  LEGACY_WEEKLY
  SUMMER_LITE
}

enum GrowthCategory {
  CHARACTER
  WELLNESS
  CREATIVITY
  RESPONSIBILITY
  COMMUNITY
}

enum LedgerReason {
  TASK_APPROVAL
  CHALLENGE_APPROVAL
  FOCUS_DECK_APPROVAL
  REWARD_REDEMPTION
  PARENT_ADJUSTMENT
  DAILY_CAP_OVERFLOW
  WEEKEND_BANK_USE
  COUNCIL_DAY
}

enum FocusDeckCategory {
  CHARACTER
  WELLNESS
  CREATIVITY
  RESPONSIBILITY
  COMMUNITY
}

enum FocusActivityCardStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FocusActivityCompletionStatus {
  IN_PROGRESS
  SUBMITTED
  SENT_BACK
  REJECTED
  REWARDED
}

enum FocusDeckLocationType {
  HOME
  OUTDOOR
  COMMUNITY
  ANY
}

enum FocusDeckDifficulty {
  EASY
  MEDIUM
  CHALLENGING
}

enum ChallengeType {
  BINARY_ROUTINE
}

enum ChallengeIntervalType {
  DAILY
  WEEKDAYS
  WEEKLY
  CUSTOM
}

enum ChallengeStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ChallengeProgressStatus {
  PENDING
  SUBMITTED
  SENT_BACK
  REJECTED
  REWARDED
}

enum RewardGrantType {
  NONE
  PHONE_TIME
  WEEKEND_BANK
  FOCUS_AREA_SWAP
}

enum RewardRedemptionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CalendarEventType {
  APPOINTMENT
  SCHOOL
  ACTIVITY
  FAMILY
  DEADLINE
  REVIEW
}

enum CalendarEventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum TaskRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum GuardianNudgeRuleType {
  NOT_TOUCHED_AFTER_ASSIGN
  NOT_STARTED_BEFORE_DUE
  OVERDUE_NOT_STARTED
  SUBMITTED_FOR_REVIEW
  DAILY_SUMMARY
}

enum GuardianNudgeStatus {
  ACTIVE
  SEEN
  DISMISSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  family        Family?
  reviewedTasks Task[]  @relation("ReviewedTasks")
  reviewedChallengeProgressLogs ChallengeProgressLog[] @relation("ReviewedChallengeProgress")
  reviewedFocusActivityCompletions FocusActivityCompletion[] @relation("ReviewedFocusActivityCompletions")
  councilDaySessions CouncilDaySession[] @relation("ConductedCouncilDays")
  requestedRewardRedemptions RewardRedemptionRequest[] @relation("RequestedRewardRedemptions")
  reviewedRewardRedemptions RewardRedemptionRequest[] @relation("ReviewedRewardRedemptions")
}

model Family {
  id                    String   @id @default(cuid())
  name                  String?
  dailyPhoneCapMinutes  Int      @default(60)
  weekendBankCapMinutes Int      @default(120)
  exchangeFocusMinutes  Int      @default(30)
  exchangePhoneMinutes  Int      @default(15)
  parentPinHash         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ownerId       String         @unique
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cubs          Cub[]
  taskTemplates TaskTemplate[]
  tasks         Task[]
  rewardStoreItems RewardStoreItem[]
  councilDaySessions CouncilDaySession[]
  guardianNudgePreferences GuardianNudgePreferences?
  guardianNudgeRules GuardianNudgeRule[]
  guardianNudges GuardianNudge[]
  challenges Challenge[]
  challengeProgressLogs ChallengeProgressLog[]
  focusActivityCards FocusActivityCard[]
  focusDeckStackItems FocusDeckStackItem[]
  focusActivityCompletions FocusActivityCompletion[]
  trainingDecks TrainingDeck[]
  rewardRedemptionRequests RewardRedemptionRequest[]
  calendarEvents CalendarEvent[]
}

model Cub {
  id                    String            @id @default(cuid())
  displayName           String
  ageBand               AgeBand
  focusMinutesEarned    Int               @default(30)
  phoneMinutesEarned    Int               @default(15)
  xpEarned              Int               @default(10)
  focusTokensEarned     Int               @default(1)
  dailyPhoneCapMinutes  Int               @default(45)
  weekendBankCapMinutes Int               @default(90)
  supervisionLevel      SupervisionLevel  @default(NEARBY)
  requiredGrowthCategories Json          @default("[\"CHARACTER\",\"WELLNESS\",\"CREATIVITY\",\"RESPONSIBILITY\",\"COMMUNITY\"]")
  focusAreaSwapCredits   Int           @default(0)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  familyId    String
  family      Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tasks       Task[]
  focusBlocks FocusBlockLog[]
  xpLedgerEntries          XpLedgerEntry[]
  focusTokenLedgerEntries  FocusTokenLedgerEntry[]
  phoneTimeLedgerEntries   PhoneTimeLedgerEntry[]
  weekendBankLedgerEntries WeekendBankLedgerEntry[]
  rewardRedemptions        RewardRedemption[]
  councilDayEntries        CouncilDayCubEntry[]
  guardianNudges           GuardianNudge[]
  challenges               Challenge[]
  challengeProgressLogs    ChallengeProgressLog[]
  focusDeckStackItems      FocusDeckStackItem[]
  focusActivityCompletions FocusActivityCompletion[]
  rewardRedemptionRequests RewardRedemptionRequest[]
  calendarEvents           CalendarEvent[]

  @@index([familyId])
}

model CalendarEvent {
  id                 String              @id @default(cuid())
  title              String
  description        String?
  eventType          CalendarEventType
  eventDate          DateTime
  startTime          String?
  endTime            String?
  status             CalendarEventStatus @default(SCHEDULED)
  linkedAssignmentId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cubId    String?
  cub      Cub?   @relation(fields: [cubId], references: [id], onDelete: SetNull)
  linkedTask Task? @relation(fields: [linkedAssignmentId], references: [id], onDelete: SetNull)

  @@index([familyId, eventDate])
  @@index([cubId])
  @@index([linkedAssignmentId])
}

model CouncilDaySession {
  id                String    @id @default(cuid())
  weekStartsOn      DateTime
  familyNotes       String?
  conductedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  familyId          String
  conductedByUserId String?

  family      Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  conductedBy User?                @relation("ConductedCouncilDays", fields: [conductedByUserId], references: [id], onDelete: SetNull)
  cubEntries  CouncilDayCubEntry[]

  @@unique([familyId, weekStartsOn])
  @@index([familyId])
}

model CouncilDayCubEntry {
  id                 String    @id @default(cuid())
  winNote            String?
  growNote           String?
  familyGoalNote     String?
  reflection         String?
  valueRatings        Json?
  bonusXpGranted     Int       @default(0)
  bonusTokensGranted Int       @default(0)
  bonusPhoneMinutesGranted Int @default(0)
  bonusGrantedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sessionId String
  cubId     String

  session               CouncilDaySession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cub                   Cub                       @relation(fields: [cubId], references: [id], onDelete: Cascade)
  xpLedgerEntries       XpLedgerEntry[]
  focusTokenLedgerEntries FocusTokenLedgerEntry[]
  phoneTimeLedgerEntries PhoneTimeLedgerEntry[]

  @@unique([sessionId, cubId])
  @@index([cubId])
}

model TaskTemplate {
  id                  String        @id @default(cuid())
  title               String
  description         String?
  category            TaskCategory  @default(CHORE)
  subcategory         String?
  growthCategory      GrowthCategory?
  proofType           TaskProofType @default(SHORT_REFLECTION)
  proofPrompt         String?
  proofChecklistItems Json?
  recurrence          TaskRecurrence @default(NONE)
  recurrenceConfig    Json?
  isActive            Boolean       @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@index([familyId])
}

model Task {
  id                String        @id @default(cuid())
  title             String
  description       String?
  category          TaskCategory  @default(CHORE)
  subcategory       String?
  growthCategory    GrowthCategory?
  proofType         TaskProofType
  proofPrompt       String?
  proofChecklistItems Json?
  focusMinutesEarned Int          @default(30)
  phoneMinutesEarned Int          @default(15)
  xpEarned          Int          @default(10)
  focusTokensEarned Int          @default(1)
  status            TaskStatus    @default(AVAILABLE)
  reflection        String?
  proofLink         String?
  checklistData     Json?
  timeLoggedMinutes Int?
  reviewNote        String?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  claimedAt         DateTime?
  dueAt             DateTime?
  dueAtHasTime      Boolean       @default(false)
  recurrence        TaskRecurrence @default(NONE)
  recurrenceConfig  Json?
  isUrgent          Boolean       @default(false)
  focusSessionStartedAt DateTime?
  startedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  familyId         String
  cubId            String?
  templateId       String?
  focusActivityCardId String?
  trainingDeckId   String?
  reviewedByUserId String?

  family     Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cub        Cub?            @relation(fields: [cubId], references: [id], onDelete: SetNull)
  template   TaskTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  focusActivityCard FocusActivityCard? @relation(fields: [focusActivityCardId], references: [id], onDelete: SetNull)
  trainingDeck TrainingDeck? @relation(fields: [trainingDeckId], references: [id], onDelete: SetNull)
  reviewedBy User?           @relation("ReviewedTasks", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  focusBlocks FocusBlockLog[]
  xpLedgerEntries          XpLedgerEntry[]
  focusTokenLedgerEntries  FocusTokenLedgerEntry[]
  phoneTimeLedgerEntries   PhoneTimeLedgerEntry[]
  weekendBankLedgerEntries WeekendBankLedgerEntry[]
  guardianNudges           GuardianNudge[]
  linkedCalendarEvents     CalendarEvent[]

  @@index([familyId])
  @@index([cubId])
  @@index([status])
  @@index([focusActivityCardId])
  @@index([trainingDeckId])
}

model FocusBlockLog {
  id              String          @id @default(cuid())
  durationMinutes Int
  startedAt       DateTime
  note            String?
  growthCategory  GrowthCategory?
  createdAt       DateTime        @default(now())

  cubId  String
  taskId String?

  cub  Cub   @relation(fields: [cubId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([cubId])
  @@index([taskId])
}

model XpLedgerEntry {
  id        String       @id @default(cuid())
  amount    Int
  reason    LedgerReason
  note      String?
  growthCategory GrowthCategory?
  createdAt DateTime     @default(now())

  cubId           String
  sourceTaskId    String?
  sourceChallengeProgressLogId String?
  sourceFocusActivityCompletionId String?
  councilDayCubEntryId String?
  createdByUserId String?

  cub        Cub   @relation(fields: [cubId], references: [id], onDelete: Cascade)
  sourceTask Task? @relation(fields: [sourceTaskId], references: [id], onDelete: SetNull)
  sourceChallengeProgressLog ChallengeProgressLog? @relation(fields: [sourceChallengeProgressLogId], references: [id], onDelete: SetNull)
  sourceFocusActivityCompletion FocusActivityCompletion? @relation(fields: [sourceFocusActivityCompletionId], references: [id], onDelete: SetNull)
  councilDayCubEntry CouncilDayCubEntry? @relation(fields: [councilDayCubEntryId], references: [id], onDelete: SetNull)

  @@index([cubId])
  @@index([sourceTaskId])
  @@index([sourceChallengeProgressLogId])
  @@index([sourceFocusActivityCompletionId])
  @@index([councilDayCubEntryId])
  @@index([createdAt])
}

model FocusTokenLedgerEntry {
  id        String       @id @default(cuid())
  amount    Int
  reason    LedgerReason
  note      String?
  createdAt DateTime     @default(now())

  cubId           String
  sourceTaskId    String?
  sourceChallengeProgressLogId String?
  sourceFocusActivityCompletionId String?
  councilDayCubEntryId String?
  createdByUserId String?

  cub        Cub   @relation(fields: [cubId], references: [id], onDelete: Cascade)
  sourceTask Task? @relation(fields: [sourceTaskId], references: [id], onDelete: SetNull)
  sourceChallengeProgressLog ChallengeProgressLog? @relation(fields: [sourceChallengeProgressLogId], references: [id], onDelete: SetNull)
  sourceFocusActivityCompletion FocusActivityCompletion? @relation(fields: [sourceFocusActivityCompletionId], references: [id], onDelete: SetNull)
  councilDayCubEntry CouncilDayCubEntry? @relation(fields: [councilDayCubEntryId], references: [id], onDelete: SetNull)

  @@index([cubId])
  @@index([sourceTaskId])
  @@index([sourceChallengeProgressLogId])
  @@index([sourceFocusActivityCompletionId])
  @@index([councilDayCubEntryId])
  @@index([createdAt])
}

model PhoneTimeLedgerEntry {
  id        String       @id @default(cuid())
  amount    Int
  reason    LedgerReason
  note      String?
  createdAt DateTime     @default(now())

  cubId           String
  sourceTaskId    String?
  sourceChallengeProgressLogId String?
  sourceFocusActivityCompletionId String?
  councilDayCubEntryId String?
  createdByUserId String?

  cub        Cub   @relation(fields: [cubId], references: [id], onDelete: Cascade)
  sourceTask Task? @relation(fields: [sourceTaskId], references: [id], onDelete: SetNull)
  sourceChallengeProgressLog ChallengeProgressLog? @relation(fields: [sourceChallengeProgressLogId], references: [id], onDelete: SetNull)
  sourceFocusActivityCompletion FocusActivityCompletion? @relation(fields: [sourceFocusActivityCompletionId], references: [id], onDelete: SetNull)
  councilDayCubEntry CouncilDayCubEntry? @relation(fields: [councilDayCubEntryId], references: [id], onDelete: SetNull)

  @@index([cubId])
  @@index([sourceTaskId])
  @@index([sourceChallengeProgressLogId])
  @@index([sourceFocusActivityCompletionId])
  @@index([councilDayCubEntryId])
  @@index([createdAt])
}

model WeekendBankLedgerEntry {
  id        String       @id @default(cuid())
  amount    Int
  reason    LedgerReason
  note      String?
  createdAt DateTime     @default(now())

  cubId           String
  sourceTaskId    String?
  createdByUserId String?

  cub        Cub   @relation(fields: [cubId], references: [id], onDelete: Cascade)
  sourceTask Task? @relation(fields: [sourceTaskId], references: [id], onDelete: SetNull)

  @@index([cubId])
  @@index([sourceTaskId])
  @@index([createdAt])
}

model RewardStoreItem {
  id              String          @id @default(cuid())
  title           String
  description     String?
  costFocusTokens Int             @default(1)
  grantType       RewardGrantType @default(NONE)
  minutesGranted  Int?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  redemptions RewardRedemption[]
  redemptionRequests RewardRedemptionRequest[]

  @@index([familyId])
}

model RewardRedemptionRequest {
  id        String                        @id @default(cuid())
  status    RewardRedemptionRequestStatus @default(PENDING)
  requestedAt DateTime                    @default(now())
  reviewedAt  DateTime?
  reviewNote  String?

  familyId          String
  cubId             String
  rewardStoreItemId String
  requestedByUserId String?
  reviewedByUserId  String?

  family          Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cub             Cub             @relation(fields: [cubId], references: [id], onDelete: Cascade)
  rewardStoreItem RewardStoreItem @relation(fields: [rewardStoreItemId], references: [id], onDelete: Cascade)
  requestedBy     User?           @relation("RequestedRewardRedemptions", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  reviewedBy      User?           @relation("ReviewedRewardRedemptions", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([familyId, status])
  @@index([cubId])
  @@index([rewardStoreItemId])
}

model RewardRedemption {
  id                    String   @id @default(cuid())
  focusTokensSpent      Int
  phoneMinutesGranted   Int      @default(0)
  weekendBankMinutesGranted Int  @default(0)
  createdAt             DateTime @default(now())

  cubId             String
  rewardStoreItemId String
  createdByUserId   String

  cub             Cub             @relation(fields: [cubId], references: [id], onDelete: Cascade)
  rewardStoreItem RewardStoreItem @relation(fields: [rewardStoreItemId], references: [id], onDelete: Cascade)

  @@index([cubId])
  @@index([rewardStoreItemId])
}

model GuardianNudgePreferences {
  id                  String   @id @default(cuid())
  quietHoursStart     String?  // HH:mm local
  quietHoursEnd       String?  // HH:mm local
  timezone            String   @default("America/New_York")
  dailySummaryEnabled Boolean  @default(false)
  dailySummaryTime    String?  // HH:mm local
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  familyId String @unique
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model GuardianNudgeRule {
  id            String                @id @default(cuid())
  type          GuardianNudgeRuleType
  enabled       Boolean               @default(true)
  offsetMinutes Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  familyId        String
  createdByUserId String?

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, type])
  @@index([familyId])
}

model GuardianNudge {
  id          String                @id @default(cuid())
  type        GuardianNudgeRuleType
  status      GuardianNudgeStatus   @default(ACTIVE)
  message     String
  dedupeKey   String
  triggeredAt DateTime              @default(now())
  seenAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  familyId String
  taskId   String?
  cubId    String?
  ruleId   String?

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  task   Task?  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  cub    Cub?   @relation(fields: [cubId], references: [id], onDelete: SetNull)

  @@unique([familyId, dedupeKey])
  @@index([familyId, status])
  @@index([taskId])
}

model Challenge {
  id                  String               @id @default(cuid())
  challengeType       ChallengeType        @default(BINARY_ROUTINE)
  title               String
  description         String?
  intervalType        ChallengeIntervalType
  intervalConfig      Json?
  proofType           TaskProofType
  proofPrompt         String?
  proofChecklistItems Json?
  growthCategory      GrowthCategory?
  xpEarned            Int                  @default(10)
  focusTokensEarned   Int                  @default(1)
  phoneMinutesEarned  Int                  @default(15)
  status              ChallengeStatus      @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  familyId        String
  cubId           String
  createdByUserId String?

  family       Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cub          Cub                   @relation(fields: [cubId], references: [id], onDelete: Cascade)
  progressLogs ChallengeProgressLog[]

  @@index([familyId])
  @@index([cubId])
  @@index([status])
}

model ChallengeProgressLog {
  id            String                  @id @default(cuid())
  intervalStart DateTime
  intervalEnd   DateTime
  completed     Boolean?
  reflection    String?
  checklistData Json?
  reviewNote    String?
  status        ChallengeProgressStatus @default(PENDING)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  challengeId      String
  familyId         String
  cubId            String
  reviewedByUserId String?

  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  family       Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cub          Cub       @relation(fields: [cubId], references: [id], onDelete: Cascade)
  reviewedBy   User?     @relation("ReviewedChallengeProgress", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  xpLedgerEntries         XpLedgerEntry[]
  focusTokenLedgerEntries FocusTokenLedgerEntry[]
  phoneTimeLedgerEntries  PhoneTimeLedgerEntry[]

  @@unique([challengeId, intervalStart])
  @@index([familyId])
  @@index([cubId])
  @@index([status])
  @@index([challengeId])
}

model TrainingDeck {
  id              String   @id @default(cuid())
  milestoneNumber Int
  title           String
  description     String?
  slug            String
  sortOrder       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cards    FocusActivityCard[]
  tasks    Task[]

  @@unique([familyId, slug])
  @@index([familyId])
}

model FocusActivityCard {
  id                  String                  @id @default(cuid())
  title               String
  description         String?
  instructions        String?
  estimatedMinutes    Int?
  locationType        FocusDeckLocationType?
  difficulty          FocusDeckDifficulty?
  categoryPoints      Json
  proofType           TaskProofType
  proofPrompt         String?
  proofChecklistItems Json?
  focusMinutesEarned  Int                     @default(30)
  phoneMinutesEarned  Int                     @default(15)
  xpEarned            Int                     @default(10)
  focusTokensEarned   Int                     @default(1)
  status              FocusActivityCardStatus   @default(DRAFT)
  starterKey          String?
  trainingDeckId      String?
  sortOrder           Int                     @default(0)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  familyId        String
  createdByUserId String?

  family       Family                  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  trainingDeck TrainingDeck?           @relation(fields: [trainingDeckId], references: [id], onDelete: SetNull)
  stackItems   FocusDeckStackItem[]
  completions  FocusActivityCompletion[]
  tasks        Task[]

  @@unique([familyId, starterKey])
  @@index([familyId])
  @@index([status])
  @@index([trainingDeckId])
}

model FocusDeckStackItem {
  id           String   @id @default(cuid())
  weekStartsOn DateTime
  createdAt    DateTime @default(now())

  familyId String
  cubId    String
  cardId   String

  family Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cub    Cub               @relation(fields: [cubId], references: [id], onDelete: Cascade)
  card   FocusActivityCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cubId, cardId, weekStartsOn])
  @@index([familyId])
  @@index([cubId])
  @@index([weekStartsOn])
}

model FocusActivityCompletion {
  id            String                        @id @default(cuid())
  weekStartsOn  DateTime
  status        FocusActivityCompletionStatus @default(IN_PROGRESS)
  reflection    String?
  proofLink     String?
  checklistData Json?
  reviewNote    String?
  startedAt     DateTime                      @default(now())
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  familyId         String
  cubId            String
  cardId           String
  reviewedByUserId String?

  family       Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  cub          Cub               @relation(fields: [cubId], references: [id], onDelete: Cascade)
  card         FocusActivityCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  reviewedBy   User?             @relation("ReviewedFocusActivityCompletions", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  xpLedgerEntries         XpLedgerEntry[]
